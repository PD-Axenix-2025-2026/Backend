PDAXENIX_APP_NAME="Аналитический сервис логистики путешествия"
PDAXENIX_APP_ENV=dev
PDAXENIX_DEBUG=false
PDAXENIX_LOG_LEVEL=INFO
PDAXENIX_API_PREFIX=/api
